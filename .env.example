# Copy this file's contents into your Netlify site's Environment Variables
# (Site settings → Environment variables) — do NOT commit a real .env file.
# These are only used server-side, inside netlify/functions/submit-lead.js.

# Your Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase API settings → service_role key (NOT the anon/public key).
# This key bypasses Row Level Security — it must only ever be used in a
# server-side context like this Netlify Function, never in frontend code.
SUPABASE_SERVICE_ROLE_KEY=
