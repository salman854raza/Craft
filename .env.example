# Copy these into Vercel Project Settings → Environment Variables.
# Do NOT commit a real .env file — these values go in Vercel's dashboard only.
# Used server-side only inside api/submit-lead.js.

# Your Supabase project URL
SUPABASE_URL=https://utllswqajudzehlfwryv.supabase.co

# Supabase anon/public key — safe to use server-side with the INSERT-only
# RLS policy on the leads table (anon can INSERT but never SELECT).
# Find it at: Supabase Dashboard → Project Settings → API → anon public
SUPABASE_ANON_KEY=
